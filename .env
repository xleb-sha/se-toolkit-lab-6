# See wiki/dotenv-docker-secret.md

# app
APP_NAME="Learning Management Service"
APP_DEBUG=false
APP_RELOAD=false
APP_CONTAINER_ADDRESS=0.0.0.0
APP_CONTAINER_PORT=8000
APP_HOST_ADDRESS=127.0.0.1
APP_HOST_PORT=42001
APP_ENABLE_INTERACTIONS=true
APP_ENABLE_LEARNERS=true

# Secret key used to authorize in the backend LMS API
LMS_API_KEY=1234

# Autochecker API credentials for the ETL pipeline
AUTOCHECKER_API_URL=https://auche.namaz.live
AUTOCHECKER_EMAIL=g.shamiev@innopolis.university
AUTOCHECKER_PASSWORD=xleb-shaxleb_shaman

# postgres
POSTGRES_DB=db-lab-6
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_ADDRESS=127.0.0.1
POSTGRES_HOST_PORT=42004

# pgadmin
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_HOST_ADDRESS=0.0.0.0
PGADMIN_HOST_PORT=42003

# caddy
CADDY_CONTAINER_PORT=80
CADDY_HOST_ADDRESS=0.0.0.0
CADDY_HOST_PORT=42002

# agent API base URL (for query_api tool)
AGENT_API_BASE_URL=http://localhost:42001

# grafana (optional)
# GF_SECURITY_ADMIN_USER=admin
# GF_SECURITY_ADMIN_PASSWORD=admin
# GRAFANA_HOST_ADDRESS=0.0.0.0
# GRAFANA_HOST_PORT=3000

# ---

# Constants that shouldn't be changed.
# Written here for convenient referencing in docs.
CONST_POSTGRESQL_SERVICE_NAME=postgres
CONST_POSTGRESQL_SERVER_NAME=postgres-lab-6
CONST_POSTGRESQL_DEFAULT_PORT=5432
